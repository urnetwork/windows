<?xml version="1.0" encoding="utf-8"?>
<!-- URnetwork MSI (WiX v5). Installs the tray app, the urnetworkd service, the
     vendored wintun DLL, and (optionally) the split-tunnel driver. Per-machine.
     The WindowsAppRuntime is chained by the outer bundle (see README); this
     package is the payload. Distributed via the Microsoft Store as a Win32 MSI.
     SPDX-License-Identifier: MPL-2.0 -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall">

  <Package Name="URnetwork" Manufacturer="URnetwork" Version="0.0.1.0"
           UpgradeCode="a7c1e2d3-4b5f-6081-9c2d-3e4f50617283"
           Scope="perMachine" Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of URnetwork is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Build binaries are staged under $(var.BinDir) by the .wixproj. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="URnetwork">

        <!-- Tray app + SDK -->
        <Component Id="AppExe" Guid="*">
          <File Id="URnetworkExe" Source="$(var.BinDir)\URnetwork.exe" KeyPath="yes" />
        </Component>
        <Component Id="SdkDll" Guid="*">
          <File Id="URnetworkSdkDll" Source="$(var.BinDir)\URnetworkSdk.dll" KeyPath="yes" />
        </Component>

        <!-- Localized UI strings: the MakePri index of Strings\<locale>\Resources.resw
             (generated from urnetwork/localizations). The app is unpackaged, so there
             is no package to carry it — MRT Core loads it by path from next to the exe,
             and without it every string renders as its key id. -->
        <Component Id="ResourcesPri" Guid="*">
          <File Id="resourcesPri" Source="$(var.BinDir)\resources.pri" KeyPath="yes" />
        </Component>

        <!-- Service + wintun -->
        <Component Id="ServiceExe" Guid="*">
          <File Id="urnetworkdExe" Source="$(var.BinDir)\urnetworkd.exe" KeyPath="yes" />
          <!-- Register urnetworkd as an auto-start LocalSystem service. -->
          <ServiceInstall Id="UrnetworkdService" Name="urnetworkd"
                          DisplayName="URnetwork Service" Type="ownProcess"
                          Start="auto" ErrorControl="normal"
                          Description="Runs the URnetwork VPN tunnel."
                          Account="LocalSystem">
            <ServiceConfig DelayedAutoStart="no" OnInstall="yes" OnReinstall="yes" />
            <!-- restart on crash (plan M4) -->
            <util:ServiceConfig xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
                                FirstFailureActionType="restart"
                                SecondFailureActionType="restart"
                                ThirdFailureActionType="none"
                                RestartServiceDelayInSeconds="5" ResetPeriodInDays="1" />
          </ServiceInstall>
          <ServiceControl Id="UrnetworkdControl" Name="urnetworkd"
                          Start="install" Stop="both" Remove="uninstall" Wait="yes" />
        </Component>
        <Component Id="WintunDll" Guid="*">
          <File Id="wintunDll" Source="$(var.BinDir)\wintun.dll" KeyPath="yes" />
        </Component>

        <!-- Third-party attributions: the notices index (checked in) + Wintun's
             verbatim prebuilt-binaries license (staged by tools/fetch-deps.ps1). -->
        <!-- One file per component: WiX auto-GUID ('*') requires a single file (or a
             versioned keypath), so these two unversioned .txt files must be separate
             components (else WIX0367). -->
        <Component Id="ThirdPartyNotices" Guid="*">
          <File Id="ThirdPartyNoticesTxt" Source="$(sys.SOURCEFILEDIR)..\THIRD-PARTY-NOTICES.txt" KeyPath="yes" />
        </Component>
        <Component Id="WintunLicense" Guid="*">
          <File Id="WintunLicenseTxt" Source="$(sys.SOURCEFILEDIR)..\third_party\wintun\wintun-license.txt" KeyPath="yes" />
        </Component>

        <!-- Split-tunnel driver payload. The MSI only lays down the .sys; the
             urnetworkd service (LocalSystem) registers + starts it on demand and
             stops + deletes it on teardown (SplitTunnelClient). Windows Installer
             can't host a kernel-driver service (SERVICE_KERNEL_DRIVER is not a
             valid ServiceInstall type). Attestation-signed in production.
             Compiled in only when the driver was built: -p:IncludeDriver=true on
             the .wixproj (build.ps1 -IncludeDriver) defines IncludeDriver. Without
             it the WFP driver / split tunneling is omitted and the .sys need not
             exist at package time. -->
        <?ifdef IncludeDriver ?>
        <Component Id="SplitTunnelDriver" Guid="*" Condition="INSTALLDRIVER=1">
          <File Id="SplitTunnelSys" Source="$(var.BinDir)\SplitTunnel.sys" KeyPath="yes" />
        </Component>
        <?endif?>

      </Directory>
    </StandardDirectory>

    <!-- urnetwork:// protocol handler (OAuth callbacks + deep links) -->
    <StandardDirectory Id="TARGETDIR">
      <Component Id="UriScheme" Guid="*">
        <RegistryKey Root="HKLM" Key="Software\Classes\urnetwork">
          <RegistryValue Type="string" Value="URL:URnetwork Protocol" />
          <RegistryValue Name="URL Protocol" Type="string" Value="" />
          <RegistryKey Key="shell\open\command">
            <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER]URnetwork.exe&quot; &quot;%1&quot;" />
          </RegistryKey>
        </RegistryKey>
      </Component>
    </StandardDirectory>

    <Feature Id="Main" Title="URnetwork" Level="1">
      <ComponentRef Id="AppExe" />
      <ComponentRef Id="SdkDll" />
      <ComponentRef Id="ResourcesPri" />
      <ComponentRef Id="ServiceExe" />
      <ComponentRef Id="WintunDll" />
      <ComponentRef Id="ThirdPartyNotices" />
      <ComponentRef Id="WintunLicense" />
      <ComponentRef Id="UriScheme" />
    </Feature>
    <?ifdef IncludeDriver ?>
    <Feature Id="SplitTunnel" Title="Per-app split tunneling" Level="1">
      <ComponentRef Id="SplitTunnelDriver" />
    </Feature>

    <Property Id="INSTALLDRIVER" Value="1" />
    <?endif?>
  </Package>
</Wix>
