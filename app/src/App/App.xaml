<?xml version="1.0" encoding="utf-8"?>
<!-- URnetwork app resources. The app runs the brand dark theme (macOS parity):
     #101010 background, #1C1C1C cards, pale yellow accent for primary actions,
     brand blue for switch on-states. The Ur* brushes mirror UrColors.h - keep
     the two in sync.
     SPDX-License-Identifier: MPL-2.0 -->
<Application
    x:Class="URnetwork.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <!-- "Default" is the dark dictionary; the app requests Dark. -->
                <ResourceDictionary x:Key="Default">
                    <!-- pale yellow accent for primary buttons (Connect, dialog
                         primaries), with dark text for contrast -->
                    <SolidColorBrush x:Key="AccentButtonBackground" Color="#EFF7BB" />
                    <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#F5FBD1" />
                    <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#D9E3A3" />
                    <SolidColorBrush x:Key="AccentButtonBackgroundDisabled" Color="#33EFF7BB" />
                    <SolidColorBrush x:Key="AccentButtonForeground" Color="#101010" />
                    <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="#101010" />
                    <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="#101010" />
                    <SolidColorBrush x:Key="AccentButtonForegroundDisabled" Color="#66101010" />
                    <SolidColorBrush x:Key="AccentButtonBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="AccentButtonBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="AccentButtonBorderBrushPressed" Color="Transparent" />
                    <!-- brand blue switch on-state -->
                    <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#638BFC" />
                    <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#7FA0FC" />
                    <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#5378E0" />
                    <SolidColorBrush x:Key="ToggleSwitchFillOnDisabled" Color="#33638BFC" />
                    <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="#638BFC" />
                    <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="#7FA0FC" />
                    <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed" Color="#5378E0" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- brand palette (mirrors UrColors.h) -->
            <SolidColorBrush x:Key="UrBackgroundBrush" Color="#101010" />
            <SolidColorBrush x:Key="UrCardBrush" Color="#1C1C1C" />
            <SolidColorBrush x:Key="UrBorderBrush" Color="#1FFFFFFF" />
            <SolidColorBrush x:Key="UrTextBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="UrTextMutedBrush" Color="#989898" />
            <SolidColorBrush x:Key="UrTextFaintBrush" Color="#5A5A5A" />
            <SolidColorBrush x:Key="UrDangerBrush" Color="#F8523B" />
            <SolidColorBrush x:Key="UrAccentBrush" Color="#EFF7BB" />
            <SolidColorBrush x:Key="UrGreenBrush" Color="#87FB67" />
            <SolidColorBrush x:Key="UrPinkBrush" Color="#ED8FFF" />
            <SolidColorBrush x:Key="UrCoralBrush" Color="#FF6C58" />
            <!-- coral at 15% alpha: the unapplied-dns-recommendation pill background
                 (iOS Color.urCoral.opacity(0.15)) -->
            <SolidColorBrush x:Key="UrCoralSubtleBrush" Color="#26FF6C58" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
