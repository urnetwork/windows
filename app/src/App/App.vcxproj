<?xml version="1.0" encoding="utf-8"?>
<!-- URnetwork tray app: WinUI 3 (Windows App SDK), C++/WinRT, unpackaged.
     WindowsPackageType=None auto-initializes the Windows App SDK bootstrapper;
     the installer must still deploy the WindowsAppRuntime (see installer/).
     This is the most toolchain-dependent project — verify NuGet versions in
     packages.config against the installed Windows App SDK on the build box.
     SPDX-License-Identifier: MPL-2.0 -->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- WinUI 3 / C++/WinRT build tooling via NuGet PackageReference (restored by
       `msbuild /t:restore`; see build.ps1). The package build props/targets are
       auto-imported from obj\*.nuget.g.props / .nuget.g.targets - no manual <Import>.
       GeneratePathProperty on SDK.BuildTools exposes $(PkgMicrosoft_Windows_SDK_BuildTools)
       for the MakePri path below. Versions track the installed Windows App SDK. -->
  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CppWinRT" Version="3.0.260520.1" />
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="2.2.0" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.4078.44" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.28000.2270" GeneratePathProperty="true" />
  </ItemGroup>

  <!-- C++ vcxproj + PackageReference: disable the LEGACY managed NuGet asset resolver
       (Microsoft.NuGet.targets ResolveNuGetPackageAssets). It resolves lib/ref assets
       by a managed TargetFramework, which a native project has none of, so it dies with
       "Sequence contains no elements / GiveErrorForMissingFramework". We consume these
       packages purely via their build\native props/targets (auto-imported from
       obj\*.nuget.g.props/.nuget.g.targets), not lib/ assets - so skip that resolver. -->
  <PropertyGroup>
    <ResolveNuGetPackages>false</ResolveNuGetPackages>
  </PropertyGroup>

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64"><Configuration>Debug</Configuration><Platform>x64</Platform></ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64"><Configuration>Release</Configuration><Platform>x64</Platform></ProjectConfiguration>
    <ProjectConfiguration Include="Debug|ARM64"><Configuration>Debug</Configuration><Platform>ARM64</Platform></ProjectConfiguration>
    <ProjectConfiguration Include="Release|ARM64"><Configuration>Release</Configuration><Platform>ARM64</Platform></ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{A1B2C3D4-0003-4E5F-8A9B-000000000003}</ProjectGuid>
    <RootNamespace>URnetwork</RootNamespace>
    <TargetName>URnetwork</TargetName>  <!-- URnetwork.exe (the WiX + tray registration expect it) -->
    <ConfigurationType>Application</ConfigurationType>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>None</WindowsPackageType>
    <AppxPackage>false</AppxPackage>
    <AppContainerApplication>false</AppContainerApplication>
    <!-- PRI: use the DEFAULT MrtCore path (EnableCoreMrtTooling stays true). Its PRI tasks
         (GetSdkFileFullPath / GenerateProjectPriFile / ExpandPriContent) load from VS's AppxPackage
         component (Microsoft.Build.AppxPackage.dll / Microsoft.Build.Packaging.Pri.Tasks.dll), which
         is now provisioned via Microsoft.VisualStudio.ComponentGroup.UWP.BuildTools (".NET WinUI app
         development build tools"; NOT the ".VC" variant, which is the C++ UWP compiler support and
         lacks these managed tasks) - see all/windows/packer/scripts/provision.ps1. We previously set
         EnableMsixTooling=true to use the WASDK self-contained Msix PRI tasks because VS *Build Tools*
         lacked that component. -->
    <!-- MrtCore names the project PRI $(TargetName).pri (= URnetwork.pri) by default. The app loads
         "resources.pri" by path from next to the exe (unpackaged), and installer/Package.wxs harvests
         that exact name - so pin the PRI output filename. (UrnVerifyResourcesPri below also stages a
         $(TargetName).pri -> resources.pri fallback in case a future SDK ignores this property.) -->
    <ProjectPriFileName>resources.pri</ProjectPriFileName>
    <CppWinRTOptimized>true</CppWinRTOptimized>
    <CppWinRTRootNamespaceAutoMerge>true</CppWinRTRootNamespaceAutoMerge>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
    <!-- Default language for MakePri. An unpackaged app has no appxmanifest to
         carry it, so the PRI config takes it from here; it must name a folder
         that exists under Strings\ (Strings\en\Resources.resw) or the resources
         have no default candidate and every lookup falls back to the key id. -->
    <DefaultLanguage>en</DefaultLanguage>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <UseDebugLibraries Condition="'$(Configuration)'=='Debug'">true</UseDebugLibraries>
    <UseDebugLibraries Condition="'$(Configuration)'=='Release'">false</UseDebugLibraries>
    <WholeProgramOptimization Condition="'$(Configuration)'=='Release'">true</WholeProgramOptimization>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <!-- MakePri indexes this project's resources at the root of the app's resource
       map, so a resw entry lands at ms-resource:///Resources/<id> — what MRT Core
       asks for (Localization.cpp). Without the empty initial path an unpackaged
       C++ WinUI app prefixes the URIs and the runtime resolves nothing: a Windows
       App SDK known issue whose documented fix is exactly this property, placed
       right after Microsoft.Cpp.props.
       https://learn.microsoft.com/windows/apps/windows-app-sdk/release-notes/windows-app-sdk-1-0 -->
  <PropertyGroup>
    <AppxPriInitialPath></AppxPriInitialPath>
  </PropertyGroup>

  <!-- WebView2 (embedded Stripe checkout, BalanceSheets.cpp). Force the SDK's
       WinRT flavor: its targets add the Microsoft.Web.WebView2.Core.winmd
       reference C++/WinRT projects from, and skip the Win32 WebView2Loader —
       the WinAppSDK runtime provides Microsoft.Web.WebView2.Core.dll (with the
       loader linked in) through its lifted-class registrations. Pin it explicitly
       rather than rely on the package's auto-detection (off
       $(MicrosoftWindowsAppSDKPackageDir)), so the flavor is deterministic. -->
  <PropertyGroup>
    <WebView2UseWinRT>true</WebView2UseWinRT>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <PrecompiledHeader>Use</PrecompiledHeader>
      <PrecompiledHeaderFile>pch.h</PrecompiledHeaderFile>
      <!-- $(IntDir) (intermediate ROOT): the WinUI XAML markup compiler writes
           App.xaml.g.h / MainWindow.xaml.g.h (+ their .g.hpp, and XamlTypeInfo/
           XamlBindingInfo) to $(XamlGeneratedOutputPath) = $(IntermediateOutputPath) =
           $(IntDir), but cppwinrt only adds $(IntDir)Generated Files\ (one level down) to
           the include path -> App.xaml.h's #include "App.xaml.g.h" would C1083 without it.
           $(MSBuildProjectDirectory) (the project dir, src\App): the markup-generated impl
           units (XamlTypeInfo.g.cpp / XamlTypeInfo.Impl.g.cpp / XamlLibMetadataProvider.g.cpp)
           live in $(IntDir) but #include the AUTHORED "App.xaml.h" / "MainWindow.xaml.h",
           which sit in the project dir; MSVC resolves a quoted include relative to the
           including file's own dir (=$(IntDir)) then /I, so without the project dir on /I
           XamlTypeInfo.g.cpp fails C1083 'App.xaml.h'. Our hand-authored .cpp don't hit
           this only because they physically sit next to those headers. -->
      <AdditionalIncludeDirectories>$(MSBuildProjectDirectory);$(IntDir);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <!-- DISABLE_XAML_GENERATED_MAIN: the WinUI markup compiler emits an app bootstrap
           (wWinMain + its winrt module glue, guarded by #ifndef DISABLE_XAML_GENERATED_MAIN)
           into the generated XamlTypeInfo.g.cpp unit. We ship our OWN entry point in
           main.cpp (single-instance AppInstance redirect + AppUserModelId + the same
           Application::Start/make<App>), so the generated one is redundant. Once
           UrnCompileGeneratedXamlImpl adds XamlTypeInfo.g.cpp to the build, its wWinMain
           collides with main.obj (LNK2005) and its bootstrap references
           WINRT_GetActivationFactory / WINRT_CanUnloadNow (LNK2001, normally defined by the
           module.g.cpp we don't compile) - defining this compiles the whole block out, and
           since ONLY that generated unit referenced those symbols, both errors clear. -->
      <PreprocessorDefinitions>DISABLE_XAML_GENERATED_MAIN;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <RuntimeLibrary Condition="'$(Configuration)'=='Debug'">MultiThreadedDebugDLL</RuntimeLibrary>
      <RuntimeLibrary Condition="'$(Configuration)'=='Release'">MultiThreadedDLL</RuntimeLibrary>
      <Optimization Condition="'$(Configuration)'=='Release'">MaxSpeed</Optimization>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <AdditionalLibraryDirectories>$(UrnSdkDir);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <!-- crypt32.lib: WalletConnect.cpp uses CryptBinaryToStringA (Base64) -> __imp_CryptBinaryToStringA. -->
      <AdditionalDependencies>URnetworkSdk.lib;shell32.lib;advapi32.lib;ws2_32.lib;iphlpapi.lib;crypt32.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
    <Manifest>
      <AdditionalManifestFiles>app.manifest</AdditionalManifestFiles>
    </Manifest>
    <PostBuildEvent>
      <Command>copy /y "$(UrnSdkDir)URnetworkSdk.dll" "$(OutDir)"</Command>
    </PostBuildEvent>
  </ItemDefinitionGroup>

  <!-- WalletConnect Cloud project id (src/App/Config.h). Injected by the build
       machine / CI the way android takes it from local.properties:
       msbuild ... /p:UrnWalletConnectProjectId=<project id>
       Unset is fine: the wallet-connect bridge then drives injected
       (browser-extension) wallets only. -->
  <ItemDefinitionGroup Condition="'$(UrnWalletConnectProjectId)'!=''">
    <ClCompile>
      <PreprocessorDefinitions>URN_WALLETCONNECT_PROJECT_ID=\"$(UrnWalletConnectProjectId)\";%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>

  <!-- XAML -->
  <ItemGroup>
    <ApplicationDefinition Include="App.xaml"><SubType>Designer</SubType></ApplicationDefinition>
    <Page Include="MainWindow.xaml"><SubType>Designer</SubType></Page>
    <Midl Include="App.idl" />
    <Midl Include="MainWindow.idl" />
  </ItemGroup>

  <!-- UI strings. GENERATED from the shared store (urnetwork/localizations):
       `cd urnetwork/localizations && npm run gen` — never hand-edit a resw.
       MakePri takes the language qualifier from the folder name, indexes every
       resw into the "Resources" map, and writes resources.pri; MRT Core picks
       the right one for the user's display language at run time, falling back to
       en. Adding a locale to the store = adding one line here. -->
  <ItemGroup>
    <PRIResource Include="Strings\en\Resources.resw" />
    <PRIResource Include="Strings\ar\Resources.resw" />
    <PRIResource Include="Strings\cs\Resources.resw" />
    <PRIResource Include="Strings\de\Resources.resw" />
    <PRIResource Include="Strings\el\Resources.resw" />
    <PRIResource Include="Strings\es\Resources.resw" />
    <PRIResource Include="Strings\es-419\Resources.resw" />
    <PRIResource Include="Strings\es-MX\Resources.resw" />
    <PRIResource Include="Strings\fr\Resources.resw" />
    <PRIResource Include="Strings\he\Resources.resw" />
    <PRIResource Include="Strings\hi\Resources.resw" />
    <PRIResource Include="Strings\id\Resources.resw" />
    <PRIResource Include="Strings\it\Resources.resw" />
    <PRIResource Include="Strings\ja\Resources.resw" />
    <PRIResource Include="Strings\ko\Resources.resw" />
    <PRIResource Include="Strings\nl\Resources.resw" />
    <PRIResource Include="Strings\pl\Resources.resw" />
    <PRIResource Include="Strings\pt\Resources.resw" />
    <PRIResource Include="Strings\pt-BR\Resources.resw" />
    <PRIResource Include="Strings\pt-PT\Resources.resw" />
    <PRIResource Include="Strings\ru\Resources.resw" />
    <PRIResource Include="Strings\sv\Resources.resw" />
    <PRIResource Include="Strings\sw\Resources.resw" />
    <PRIResource Include="Strings\th\Resources.resw" />
    <PRIResource Include="Strings\uk\Resources.resw" />
    <PRIResource Include="Strings\vi\Resources.resw" />
    <PRIResource Include="Strings\zh-Hans\Resources.resw" />
    <PRIResource Include="Strings\zh-HK\Resources.resw" />
  </ItemGroup>

  <!-- Native sources -->
  <ItemGroup>
    <ClCompile Include="pch.cpp"><PrecompiledHeader>Create</PrecompiledHeader></ClCompile>
    <ClCompile Include="main.cpp" />
    <ClCompile Include="App.xaml.cpp"><DependentUpon>App.xaml</DependentUpon></ClCompile>
    <ClCompile Include="MainWindow.xaml.cpp"><DependentUpon>MainWindow.xaml</DependentUpon></ClCompile>
    <ClCompile Include="AppController.cpp" />
    <ClCompile Include="AuthSheets.cpp" />
    <ClCompile Include="BalanceSheets.cpp" />
    <ClCompile Include="Localization.cpp" />
    <ClCompile Include="LocationSheets.cpp" />
    <ClCompile Include="SdkHost.cpp" />
    <ClCompile Include="StatsFormat.cpp" />
    <ClCompile Include="StatsSheets.cpp" />
    <ClCompile Include="SubscriptionBalance.cpp" />
    <ClCompile Include="TransferChart.cpp" />
    <ClCompile Include="UsageBar.cpp" />
    <ClCompile Include="WalletConnect.cpp" />
    <ClCompile Include="ServiceClient.cpp" />
    <ClCompile Include="TrayIcon.cpp" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="pch.h" />
    <ClInclude Include="App.xaml.h"><DependentUpon>App.xaml</DependentUpon></ClInclude>
    <ClInclude Include="MainWindow.xaml.h"><DependentUpon>MainWindow.xaml</DependentUpon></ClInclude>
    <ClInclude Include="AppController.h" />
    <ClInclude Include="AuthSheets.h" />
    <ClInclude Include="BalanceSheets.h" />
    <ClInclude Include="Config.h" />
    <ClInclude Include="Localization.h" />
    <ClInclude Include="LocationSheets.h" />
    <ClInclude Include="SdkHost.h" />
    <ClInclude Include="StatsFormat.h" />
    <ClInclude Include="StatsSheets.h" />
    <ClInclude Include="SubscriptionBalance.h" />
    <ClInclude Include="TransferChart.h" />
    <ClInclude Include="UsageBar.h" />
    <ClInclude Include="UrColors.h" />
    <ClInclude Include="WalletConnect.h" />
    <ClInclude Include="ServiceClient.h" />
    <ClInclude Include="TrayIcon.h" />
    <ClInclude Include="resource.h" />
  </ItemGroup>
  <ItemGroup>
    <ResourceCompile Include="App.rc" />
  </ItemGroup>

  <!-- loose image assets, copied next to the exe for ms-appx:/// XAML sources -->
  <ItemGroup>
    <CopyFileToFolders Include="Assets\ReferralFrog.png">
      <DestinationFolders>$(OutDir)Assets</DestinationFolders>
    </CopyFileToFolders>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Common\Common.vcxproj">
      <Project>{A1B2C3D4-0001-4E5F-8A9B-000000000001}</Project>
    </ProjectReference>
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

  <!-- The app loads resources.pri by path, from next to the exe: unpackaged, there
       is no package to carry it (and the MSI ships it, see installer/Package.wxs).
       If MakePri never ran, or dropped it somewhere else, every string in the UI
       renders as its key id ("sign_in") — a silent, shipping-grade failure. Say so
       at build time instead. Warning, not Error: never break a build over it. -->
  <Target Name="UrnVerifyResourcesPri" AfterTargets="Build">
    <!-- Stage the MrtCore PRI under the runtime/installer name if it was emitted as
         $(TargetName).pri (see ProjectPriFileName above). No-op once resources.pri exists.
         Runs in the App project's AfterBuild, before the Installer project harvests it. -->
    <Copy Condition="!Exists('$(OutDir)resources.pri') and Exists('$(OutDir)$(TargetName).pri')"
          SourceFiles="$(OutDir)$(TargetName).pri" DestinationFiles="$(OutDir)resources.pri" SkipUnchangedFiles="true" />
    <Warning Condition="!Exists('$(OutDir)resources.pri')"
             Text="resources.pri is missing from $(OutDir): the app will render resource ids instead of localized strings. Check that the Strings\*\Resources.resw PRIResource items were indexed by MakePri." />
  </Target>

  <!-- (NuGet CppWinRT + Windows App SDK + WebView2 + SDK build tools .targets are
       auto-imported from obj\*.nuget.g.targets under PackageReference.) -->

  <!-- Wire the WinUI XAML markup compiler into the NATIVE C++ build. The Windows App
       SDK and C++/WinRT targets DEFINE MarkupCompilePass1/Pass2 (they generate
       App.xaml.g.h / MainWindow.xaml.g.h and the x:Name accessors + InitializeComponent)
       and even augment their *DependsOn lists, but they only auto-INVOKE them for the
       MANAGED build, via $(PrepareResourcesDependsOn) - which the WinUI targets comment
       as "used only for the Managed build". For a classic C++/WinRT .vcxproj built from
       the command line, nothing runs the passes before ClCompile, so cppwinrt's
       projection (App.g.h) is produced but the markup output (App.xaml.g.h) is not,
       giving C1083 'App.xaml.g.h' + a cascade of x:Name "identifier not found". Inject
       the passes into $(BeforeClCompileTargets) - the same native pre-compile hook
       C++/WinRT uses for its own projection (CppWinRTMakeProjections) - so they run
       after MIDL/WinMD-merge/cppwinrt and before ClCompile. This import must come after
       the C++/WinRT + WindowsAppSDK targets above so those targets are defined. -->
  <PropertyGroup>
    <BeforeClCompileTargets>$(BeforeClCompileTargets);MarkupCompilePass1;MarkupCompilePass2</BeforeClCompileTargets>
  </PropertyGroup>

  <!-- WASDK 1.7's NATIVE markup compiler takes its winmd references from
       @(WinMDReferenceToCompile) - "a filtered Item that eliminates any Managed
       Assemblies on the ReferencePath" per Microsoft.UI.Xaml.Markup.Compiler.interop.targets
       (native Pass2 does ReferenceAssemblies="@(XamlReferencesToCompile)", and for a
       native build XamlReferencesToCompile = @(WinMDReferenceToCompile)). Nothing in
       this hand-authored packages.config C++/WinRT project populates that item - neither
       CppWinRT 2.0.x nor the WinUI targets do; the C++ project system only provides it
       for its recognized XAML project types. So the markup compiler receives ZERO winmd
       references and fails with "XamlCompiler error WMC1007: Cannot resolve metadata for
       WinUI types." Populate it from the winmds already resolved onto @(ReferencePath)
       (the same set cppwinrt used to generate App.g.h), just before the markup passes,
       and only if nothing else did; fall back to the Windows App SDK package winmds if
       ReferencePath happened to carry none. The [urn-xaml] messages report what the
       markup compiler actually received (remove this whole target once XAML is green). -->
  <Target Name="UrnPopulateWinMDReferenceToCompile" BeforeTargets="MarkupCompilePass1;MarkupCompilePass2">
    <ItemGroup Condition="'@(WinMDReferenceToCompile)' == ''">
      <WinMDReferenceToCompile Include="@(ReferencePath)" Condition="'%(ReferencePath.Extension)' == '.winmd'" />
    </ItemGroup>
    <ItemGroup Condition="'@(WinMDReferenceToCompile)' == '' and '$(MicrosoftWindowsAppSDKPackageDir)' != ''">
      <WinMDReferenceToCompile Include="$(MicrosoftWindowsAppSDKPackageDir)lib\uap10.0\*.winmd" />
      <WinMDReferenceToCompile Include="$(MicrosoftWindowsAppSDKPackageDir)lib\uap10.0.18362\*.winmd" />
    </ItemGroup>
  </Target>

  <!-- Compile the generated IMPLEMENTATION units the normal WinUI/cppwinrt project system
       would add to @(ClCompile) but our forced-early markup wiring bypasses. Two families:
       (A) MARKUP units in the intermediate ROOT ($(IntDir)*.g.cpp = XamlTypeInfo.g.cpp /
           XamlTypeInfo.Impl.g.cpp / XamlLibMetadataProvider.g.cpp) + XamlMetaDataProvider.cpp -
           these carry XamlMetaDataProvider::GetXamlType/GetXmlnsDefinitions and the per-page
           InitializeComponent/Connect (LNK2001/LNK1120 without them).
       (B) The cppwinrt MODULE unit 'Generated Files\module.g.cpp' - a STANDALONE compiland
           (it starts with its own #include "pch.h") that DEFINES the module activation
           exports WINRT_GetActivationFactory / WINRT_CanUnloadNow (+ the
           winrt_get_activation_factory by-name table XAML uses to activate our runtime
           classes at startup) which XamlTypeInfo.g.obj references (LNK2001 without it).
       NOT here: the per-class cppwinrt projections (App.g.cpp / MainWindow.g.cpp /
           XamlMetaDataProvider.g.cpp). Those are generated #include FRAGMENTS with no pch.h
           of their own - compiled standalone they C1010 ('unexpected EOF looking for pch').
           Each must be #included by a host TU that already pulled in pch.h + the class's
           impl header: MainWindow.g.cpp<-MainWindow.xaml.cpp, XamlMetaDataProvider.g.cpp<-the
           markup XamlMetaDataProvider.cpp, App.g.cpp<-App.xaml.cpp (we added the missing
           `#if __has_include("App.g.cpp")` there, matching MainWindow.xaml.cpp).
       Runs after the markup passes, before ClCompile. The message lists exactly what was added. -->
  <Target Name="UrnCompileGeneratedXamlImpl" BeforeTargets="ClCompile" DependsOnTargets="MarkupCompilePass1;MarkupCompilePass2">
    <ItemGroup>
      <_UrnGenXamlCpp Include="$(IntDir)*.g.cpp" />
      <_UrnGenXamlCpp Include="$(MSBuildProjectDirectory)\XamlMetaDataProvider.cpp" Condition="Exists('$(MSBuildProjectDirectory)\XamlMetaDataProvider.cpp')" />
      <_UrnGenXamlCpp Include="$(GeneratedFilesDir)XamlMetaDataProvider.cpp"         Condition="Exists('$(GeneratedFilesDir)XamlMetaDataProvider.cpp')" />
      <_UrnGenXamlCpp Include="$(GeneratedFilesDir)module.g.cpp"                     Condition="Exists('$(GeneratedFilesDir)module.g.cpp')" />
      <ClCompile Include="@(_UrnGenXamlCpp)" />
    </ItemGroup>
  </Target>

</Project>
