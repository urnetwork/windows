<?xml version="1.0" encoding="utf-8"?>
<!-- WinUI 3 / C++/WinRT bring their build tooling via NuGet. Versions track the
     installed Windows App SDK; bump together. SPDX-License-Identifier: MPL-2.0 -->
<packages>
  <!-- WebView2 SDK (embedded Stripe checkout): winmd + headers only at build
       time; the WinAppSDK runtime carries Microsoft.Web.WebView2.Core.dll, and
       the Evergreen WebView2 Runtime is probed for at run time with a hosted-
       checkout fallback. Pin EXACTLY the version this WinAppSDK declares as its
       NuGet dependency (see Microsoft.WindowsAppSDK.nuspec); bump together. -->
  <package id="Microsoft.Web.WebView2" version="1.0.2651.64" targetFramework="native" />
  <package id="Microsoft.Windows.CppWinRT" version="2.0.240405.15" targetFramework="native" />
  <package id="Microsoft.WindowsAppSDK" version="1.6.240923002" targetFramework="native" />
  <package id="Microsoft.Windows.SDK.BuildTools" version="10.0.22621.3233" targetFramework="native" />
</packages>
